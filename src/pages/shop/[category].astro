---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import { getProducts, getCategoryLabel } from '../../lib/api';

export async function getStaticPaths() {
  return [
    { params: { category: 'jar-candles' } },
    { params: { category: 'pillar-candles' } },
    { params: { category: 'taper-candles' } },
    { params: { category: 'wax-melts' } },
  ];
}

const { category } = Astro.params;
const products = await getProducts(category);
const categoryLabel = getCategoryLabel(category);

const categories = [
  { slug: '', label: 'All Products', icon: '🕯️' },
  { slug: 'jar-candles', label: 'Jar Candles', icon: '🕯️' },
  { slug: 'pillar-candles', label: 'Pillar Candles', icon: '🏛️' },
  { slug: 'taper-candles', label: 'Taper Candles', icon: '✨' },
  { slug: 'wax-melts', label: 'Wax Melts', icon: '🌸' },
];

const categoryDescriptions: Record<string, string> = {
  'jar-candles': 'Soy and blended jar candles in signature bayou-inspired scents. Hand-poured in small batches with natural wicks for a clean 40-60 hour burn.',
  'pillar-candles': 'Handcrafted beeswax pillars that burn beautifully and fill any room with fragrance. Tall, elegant, and long-lasting.',
  'taper-candles': 'Hand-dipped beeswax tapers, sold in sets of 4. Perfect for dining tables, candleholders, and special occasions.',
  'wax-melts': 'Fragrance-packed wax melt cubes for your warmer. Strong throw, long-lasting scent — no wick required.',
};
---

<BaseLayout title={categoryLabel}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <!-- Header -->
    <div class="mb-8 sm:mb-12">
      <a href="/shop" class="inline-flex items-center text-gray-400 hover:text-gold text-sm mb-4 transition-colors">
        ← Back to Shop
      </a>
      <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-3">
        {categoryLabel}
      </h1>
      <p class="text-gray-400 text-sm sm:text-base max-w-2xl">
        {categoryDescriptions[category!] || ''}
      </p>
    </div>

    <!-- Category Tabs -->
    <div class="flex flex-wrap gap-2 sm:gap-3 mb-8 sm:mb-10">
      {categories.map(cat => (
        <a
          href={cat.slug ? `/shop/${cat.slug}` : '/shop'}
          class:list={[
            'inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-xs sm:text-sm font-medium transition-all duration-300 border',
            cat.slug === category
              ? 'bg-gold text-bayou-black border-gold'
              : 'bg-transparent text-gray-300 border-bayou-border hover:border-gold/50 hover:text-gold'
          ]}
        >
          <span>{cat.icon}</span>
          <span>{cat.label}</span>
        </a>
      ))}
    </div>

    <!-- Count -->
    <div class="flex items-center justify-between mb-6">
      <p class="text-gray-400 text-sm">{products.length} product{products.length !== 1 ? 's' : ''}</p>
    </div>

    <!-- Product Grid -->
    <ProductGrid products={products} columns={4} />
  </div>
</BaseLayout>
