---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getProduct, getProducts, formatPrice, getCategoryLabel, getCategoryIcon, getBadgeColor, getBadgeLabel } from '../../lib/api';

const { slug } = Astro.params;
const product = await getProduct(slug!);

if (!product) {
  return Astro.redirect('/shop');
}

const { title, fields } = product;
const { price, compare_price, category, short_description, badge, in_stock, sku } = fields;
const isOnSale = compare_price && compare_price > price;
const discount = isOnSale ? Math.round((1 - price / compare_price!) * 100) : 0;

// Related products
const allProducts = await getProducts(category);
const related = allProducts.filter((p: any) => p.slug !== slug).slice(0, 3);
---

<BaseLayout title={title}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <!-- Breadcrumbs -->
    <nav class="flex flex-wrap items-center gap-2 text-sm text-gray-400 mb-8">
      <a href="/" class="hover:text-gold transition-colors">Home</a>
      <span>/</span>
      <a href="/shop" class="hover:text-gold transition-colors">Shop</a>
      <span>/</span>
      <a href={`/shop/${category}`} class="hover:text-gold transition-colors">{getCategoryLabel(category)}</a>
      <span>/</span>
      <span class="text-gray-300">{title}</span>
    </nav>

    <!-- Product Detail -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 mb-16 sm:mb-24">
      <!-- Image -->
      <div class="relative aspect-square bg-bayou-card border border-bayou-border rounded-2xl flex items-center justify-center overflow-hidden">
        <span class="text-[120px] sm:text-[160px] opacity-20">{getCategoryIcon(category)}</span>

        {badge && (
          <span class:list={[
            'absolute top-4 left-4 px-3 py-1.5 text-xs font-bold uppercase tracking-wider rounded-full text-white',
            getBadgeColor(badge)
          ]}>
            {getBadgeLabel(badge)}
          </span>
        )}

        {isOnSale && (
          <span class="absolute top-4 right-4 px-3 py-1.5 text-xs font-bold rounded-full bg-red-600 text-white">
            -{discount}% OFF
          </span>
        )}
      </div>

      <!-- Info -->
      <div class="flex flex-col">
        <div class="text-xs sm:text-sm text-gold/70 uppercase tracking-wider mb-2">{getCategoryLabel(category)}</div>
        <h1 class="font-heading text-2xl sm:text-3xl md:text-4xl font-bold text-white mb-4">{title}</h1>

        <!-- Price -->
        <div class="flex items-center gap-3 mb-6">
          <span class="text-gold font-bold text-2xl sm:text-3xl">{formatPrice(price)}</span>
          {isOnSale && (
            <span class="text-gray-500 text-lg line-through">{formatPrice(compare_price!)}</span>
          )}
          {isOnSale && (
            <span class="px-2 py-0.5 bg-red-600/20 text-red-400 text-xs font-semibold rounded">Save {formatPrice(compare_price! - price)}</span>
          )}
        </div>

        <!-- Stock Status -->
        <div class="flex items-center gap-2 mb-6">
          {in_stock ? (
            <>
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              <span class="text-emerald-400 text-sm font-medium">In Stock</span>
            </>
          ) : (
            <>
              <span class="w-2 h-2 bg-red-500 rounded-full"></span>
              <span class="text-red-400 text-sm font-medium">Out of Stock</span>
            </>
          )}
          <span class="text-gray-600 text-sm ml-2">SKU: {sku}</span>
        </div>

        <!-- Description -->
        <div class="mb-8">
          <h3 class="font-heading text-white text-sm font-semibold uppercase tracking-wider mb-3">Description</h3>
          <p class="text-gray-300 leading-relaxed">{short_description}</p>
        </div>

        <!-- Add to Cart -->
        <div class="flex flex-col sm:flex-row gap-3 mb-8">
          <div class="flex items-center border border-bayou-border rounded-lg overflow-hidden">
            <button class="px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 transition-colors" aria-label="Decrease quantity">−</button>
            <span class="px-4 py-3 text-white text-center min-w-[48px]">1</span>
            <button class="px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 transition-colors" aria-label="Increase quantity">+</button>
          </div>

          <button
            class:list={[
              'flex-1 px-8 py-3 font-semibold rounded-lg transition-all duration-300 text-sm sm:text-base',
              in_stock
                ? 'bg-gold text-bayou-black hover:bg-gold-light hover:shadow-lg hover:shadow-gold/20'
                : 'bg-gray-700 text-gray-400 cursor-not-allowed'
            ]}
            disabled={!in_stock}
          >
            {in_stock ? 'Add to Cart' : 'Out of Stock'}
          </button>
        </div>

        <!-- Details -->
        <div class="border-t border-bayou-border pt-6 space-y-3">
          <div class="flex items-center gap-3 text-sm text-gray-400">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8" /></svg>
            <span>Free shipping on orders over $50</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-gray-400">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span>Handcrafted in Louisiana</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-gray-400">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
            <span>30-day hassle-free returns</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Products -->
    {related.length > 0 && (
      <section>
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-heading text-xl sm:text-2xl md:text-3xl font-bold text-white">You Might Also Like</h2>
          <a href={`/shop/${category}`} class="text-gold hover:text-gold-light text-sm font-medium transition-colors">View All →</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
          {related.map((p: any) => (
            <ProductCard product={p} />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
