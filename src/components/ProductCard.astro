---
import type { Product } from '../lib/api';
import { formatPrice, getBadgeColor, getBadgeLabel, getCategoryIcon } from '../lib/api';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const { title, slug, fields } = product;
const { price, compare_price, category, short_description, badge, in_stock, image } = fields;
const isOnSale = compare_price && compare_price > price;
const discount = isOnSale ? Math.round((1 - price / compare_price!) * 100) : 0;
---

<a href={`/products/${slug}`} class="group block">
  <div class="bg-bayou-card border border-bayou-border rounded-xl overflow-hidden transition-all duration-300 hover:border-gold/40 hover:shadow-lg hover:shadow-gold/5 hover:-translate-y-1">
    <!-- Product Image -->
    <div class="relative aspect-square bg-gradient-to-br from-bayou-dark to-bayou-card flex items-center justify-center overflow-hidden">
      {image ? (
        <img
          src={image}
          alt={title}
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      ) : (
        <span class="text-6xl sm:text-7xl opacity-30 group-hover:opacity-50 group-hover:scale-110 transition-all duration-500">
          {getCategoryIcon(category)}
        </span>
      )}

      <!-- Badge -->
      {badge && (
        <span class:list={[
          'absolute top-3 left-3 px-2.5 py-1 text-[10px] sm:text-xs font-bold uppercase tracking-wider rounded-full text-white',
          getBadgeColor(badge)
        ]}>
          {getBadgeLabel(badge)}
        </span>
      )}

      <!-- Discount badge -->
      {isOnSale && (
        <span class="absolute top-3 right-3 px-2.5 py-1 text-[10px] sm:text-xs font-bold rounded-full bg-red-600 text-white">
          -{discount}%
        </span>
      )}

      <!-- Out of stock overlay -->
      {!in_stock && (
        <div class="absolute inset-0 bg-black/60 flex items-center justify-center">
          <span class="text-white font-semibold text-sm uppercase tracking-wider">Out of Stock</span>
        </div>
      )}
    </div>

    <!-- Content -->
    <div class="p-4 sm:p-5">
      <div class="text-[10px] sm:text-xs text-gold/70 uppercase tracking-wider mb-1.5">{getCategoryIcon(category)} {category.replace('-', ' ')}</div>
      <h3 class="font-heading text-white text-sm sm:text-base font-semibold mb-2 group-hover:text-gold transition-colors line-clamp-2">{title}</h3>
      <p class="text-gray-400 text-xs sm:text-sm line-clamp-2 mb-3">{short_description}</p>

      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="text-gold font-bold text-lg">{formatPrice(price)}</span>
          {isOnSale && (
            <span class="text-gray-500 text-sm line-through">{formatPrice(compare_price!)}</span>
          )}
        </div>
        <span class="text-xs text-gray-500 opacity-0 group-hover:opacity-100 transition-opacity">View →</span>
      </div>
    </div>
  </div>
</a>
