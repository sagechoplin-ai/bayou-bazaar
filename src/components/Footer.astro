---
const year = new Date().getFullYear();
---

<footer class="bg-bayou-dark border-t border-bayou-border mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 sm:gap-12">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">⚜️</span>
          <span class="font-heading text-gold text-xl font-bold">Bayou Bazaar</span>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          Where the Bayou Meets the Browser. Handcrafted goods from the heart of Louisiana, delivered to your door.
        </p>
      </div>

      <!-- Shop Links -->
      <div>
        <h4 class="font-heading text-white text-sm font-semibold uppercase tracking-wider mb-4">Shop</h4>
        <ul class="space-y-2">
          <li><a href="/shop/fishing-lures" class="text-gray-400 hover:text-gold text-sm transition-colors">🎣 Fishing Lures</a></li>
          <li><a href="/shop/bracelets" class="text-gray-400 hover:text-gold text-sm transition-colors">📿 Bracelets</a></li>
          <li><a href="/shop/openclaw" class="text-gray-400 hover:text-gold text-sm transition-colors">🤖 OpenClaw Installs</a></li>
          <li><a href="/shop" class="text-gray-400 hover:text-gold text-sm transition-colors">All Products</a></li>
        </ul>
      </div>

      <!-- Company Links -->
      <div>
        <h4 class="font-heading text-white text-sm font-semibold uppercase tracking-wider mb-4">Company</h4>
        <ul class="space-y-2">
          <li><a href="/about" class="text-gray-400 hover:text-gold text-sm transition-colors">About Us</a></li>
          <li><a href="/contact" class="text-gray-400 hover:text-gold text-sm transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h4 class="font-heading text-white text-sm font-semibold uppercase tracking-wider mb-4">Stay Connected</h4>
        <p class="text-gray-400 text-sm mb-4">Get updates on new products and bayou deals.</p>
        <form class="flex gap-2" onsubmit="event.preventDefault()">
          <input
            type="email"
            placeholder="your@email.com"
            class="flex-1 px-3 py-2 bg-bayou-black border border-bayou-border rounded-lg text-sm text-white placeholder:text-gray-600 focus:outline-none focus:border-gold transition-colors"
          />
          <button type="submit" class="px-4 py-2 bg-gold text-bayou-black text-sm font-semibold rounded-lg hover:bg-gold-light transition-colors whitespace-nowrap">
            Join
          </button>
        </form>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-bayou-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-xs">&copy; {year} Bayou Bazaar. All rights reserved. Powered by WollyCMS.</p>
      <p class="text-gray-600 text-xs">Made with ⚜️ in Louisiana</p>
    </div>
  </div>
</footer>
